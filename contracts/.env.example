# Monad testnet deployment config for SplitChain
# Copy to contracts/.env and fill in. .env is gitignored.

# RPC endpoint (confirm from docs.monad.xyz)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployer private key (0x-prefixed). Fund this address from the Monad faucet:
#   https://faucet.monad.xyz  (a.k.a. https://testnet.monad.xyz)
# NEVER commit a real key. This account only needs a little testnet MON for gas.
PRIVATE_KEY=
